{
  "permissions": {
    "allow": [
      "Edit(~/.claude/skills/feature-engineering-ecommerce/**)",
      "Edit(~/.claude/skills/feature-engineering-ecommerce-workspace/**)"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "/home/tough/.claude"
    ],
    "includeCoAuthoredBy": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/graphify_maintenance.py record --from-hook || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/graphify_maintenance.py flush --hook || true"
          }
        ]
      }
    ]
  }
}
