# ------------------------------------------------------------------------------
# Runtime mode
# ------------------------------------------------------------------------------
NODE_ENV=development

# ------------------------------------------------------------------------------
# Supabase (required for persistent storage in non-test environments)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------------------------
# Volcengine Ark (required for image-related AI flows and trending styles)
# Used by:
# - /api/ai/recognize-nail-style
# - /api/ai/breakdown
# - merchant style-name recognition
# - /api/ai/try-on
# - /api/ai/trending-styles
# ------------------------------------------------------------------------------
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_VISION_MODEL=doubao-seed-2-0-lite-260428
ARK_IMAGE_MODEL=doubao-seedream-5-0-260128
ARK_TRENDING_MODEL=doubao-seed-2-0-lite-260428

# ------------------------------------------------------------------------------
# OpenRouter (still required for text-only AI flows that were not migrated yet)
# Used by:
# - insights summary
#
# Pick text-capable models here. Do not point these vars at Seedream.
# ------------------------------------------------------------------------------
OPENROUTER_API_KEY=
GEMINI_IMAGE_MODEL_NAME=
INSIGHTS_MODEL_NAME=
INSIGHTS_TIMEOUT_MS=6000

# ------------------------------------------------------------------------------
# Merchant agent service (ADR-0007)
# Default demo provider is OpenRouter via the OpenAI-compatible SDK.
# The Anthropic path is optional and uses the Anthropic SDK tool_runner directly.
# ------------------------------------------------------------------------------
MODEL_PROVIDER=openrouter
AGENT_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ANTHROPIC_API_KEY=
NAILED_APP_URL=http://localhost:3000
NAILED_MERCHANT_ID=merchant-nailed-it
